DB_URL=jdbc:postgresql://localhost:5432/gymcrm
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Generate a 256-bit (64 hex chars) random secret:
# openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_OUTPUT_OF__openssl_rand_-hex_32
JWT_EXPIRATION_MS=86400000

SPRING_PROFILES_ACTIVE=prod

# Twilio — WhatsApp/SMS reminders
# Get credentials from https://console.twilio.com
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_SMS_FROM=+14155238886
